{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>gabe565/renovate-config"
  ],
  "automerge": true,
  "kubernetes": {
    "fileMatch": ["^kustomization/.*\\.yaml$"]
  },
  "regexManagers": [
    {
      "fileMatch": ["Dockerfile", "^\\.github/workflows/"],
      "matchStrings": [
        " +KUBERNETES_VERSION: +(?<currentValue>.+)",
        "ARG +KUBERNETES_VERSION=\"(?<currentValue>.+)\""
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases"
    },
    {
      "fileMatch": ["Dockerfile", "^\\.github/workflows/"],
      "matchStrings": [
        " +DOGGO_VERSION: +(?<currentValue>.+)",
        "ARG +DOGGO_VERSION=\"(?<currentValue>.+)\""
      ],
      "depNameTemplate": "mr-karan/doggo",
      "datasourceTemplate": "github-releases"
    }
  ]
}
